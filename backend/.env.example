# S-TAG Backend — Miljovariabler
# Kopier til .env og fyll inn verdiene.

# -- Generelt --
NODE_ENV=production
PORT=4000

# -- Database --
# Postgres-tilkobling. Uten denne faller backend tilbake til JSON-fil (kun dev).
DATABASE_URL=postgresql://user:password@host:5432/stag

# -- Auth --
# PAKREVD i produksjon. Generer med: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# -- CORS --
# Kommaseparerte origins. Standard dekker Vercel + localhost + Capacitor.
# CORS_ORIGINS=https://s-tag.no,https://www.s-tag.no,https://s-tag-hazel.vercel.app

# -- OAuth (Google / Apple) --
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# -- BankID-signering (Criipto Verify) --
CRIIPTO_DOMAIN=
CRIIPTO_CLIENT_ID=
CRIIPTO_CLIENT_SECRET=

# -- App-URL (brukes i BankID-callback) --
APP_BASE_URL=https://s-tag-hazel.vercel.app

# -- Chip-sikkerhet --
# Global fallback HMAC for chip-pings. Per-chip secret i DB har forrang.
CHIP_HMAC_SECRET=
# Handthev chip-whitelist (alltid pa i prod, av i lokal dev som default)
# STRICT_CHIP_REGISTER=true

# -- Admin --
# Bearer-token for /api/admin/chips-endepunkter. Tomt = endepunktene er deaktivert.
ADMIN_TOKEN=

# -- E-post (Resend) --
# Uten API-nokkel logges feedback/reset-epost kun til konsollen.
RESEND_API_KEY=
FEEDBACK_INBOX=support@s-tag.no
FEEDBACK_FROM=S-TAG <noreply@s-tag.no>

# -- Versjonering --
CONSENT_VERSION=2026-04
CONTRACT_VERSION=2026-04
