# Kopier til .env og fyll inn. IKKE commit .env til git.

# Postgres connection string. Railway gir deg denne automatisk når du legger til Postgres-plugin.
# Lokalt: la stå tom for å bruke JSON-fil (data.json).
DATABASE_URL=

# HS256-hemmelighet for JWT. Generer en lang random streng i prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=s-tag-dev-secret-change-in-production

# Tillatte CORS-origins, kommaseparert. Bruk * lokalt, konkrete domener i prod.
CORS_ORIGINS=*

# Port (Railway setter denne automatisk)
PORT=4000

# BankID-signering via Criipto/Idura (test-broker)
# Domain opprettes i Idura-dashboardet under Domains → .test.idura.broker
CRIIPTO_DOMAIN=stag.test.idura.broker
CRIIPTO_CLIENT_ID=urn:stag
CRIIPTO_CLIENT_SECRET=
# Frontend-URL der signatur-callback ligger. Må matche "Allowed callback URLs" i Idura.
APP_BASE_URL=http://localhost:3000
# Kontraktversjon som lagres i DB ved ny transfer
CONTRACT_VERSION=2026-04
CONSENT_VERSION=2026-04

# HMAC-nøkkel for chip-ping autentisering (128+ bit). La være tom i dev —
# backend vil da akseptere usignerte pings lokalt.
CHIP_HMAC_SECRET=

# Feedback / support e-post (Resend)
# Opprett gratis konto på resend.com og verifiser s-tag.no-domenet.
# Uten RESEND_API_KEY logges feedback bare til stdout.
RESEND_API_KEY=
FEEDBACK_INBOX=marianne@s-tag.no
FEEDBACK_FROM=S-TAG Support <marianne@s-tag.no>

# OAuth (Google / Apple) — valgfritt. Uten disse er Google/Apple-innlogging
# skjult i frontend og /api/auth/oauth returnerer 401 hvis kalt.
# Google: Client ID fra Google Cloud Console (OAuth 2.0 Web Client)
GOOGLE_CLIENT_ID=
# Apple: Services ID (reverse-DNS) fra Apple Developer Console
APPLE_CLIENT_ID=

# Admin-token for chip-registeret. Genereres f.eks. med:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Kreves for alle /api/admin/chips-endepunkter. Deles KUN med deg og
# produksjonspartneren som skal pre-laste chipene. Uten dette kan ingen
# endre chip-registeret.
ADMIN_TOKEN=

# Chip-register strict-modus. Når satt til 1 (default i prod) må alle
# S-TAG-koder finnes i chips-tabellen før en bruker kan registrere dem.
# Lokalt (JSON-store) er default av så utviklere slipper å seede registeret.
# Sett til 1 også lokalt hvis du vil teste hele whitelisting-flyten.
STRICT_CHIP_REGISTER=
