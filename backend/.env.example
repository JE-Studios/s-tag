# Kopier til .env og fyll inn. IKKE commit .env til git.

# Postgres connection string. Railway gir deg denne automatisk når du legger til Postgres-plugin.
# Lokalt: la stå tom for å bruke JSON-fil (data.json).
DATABASE_URL=

# HS256-hemmelighet for JWT. Generer en lang random streng i prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=s-tag-dev-secret-change-in-production

# Tillatte CORS-origins, kommaseparert. Bruk * lokalt, konkrete domener i prod.
CORS_ORIGINS=*

# Port (Railway setter denne automatisk)
PORT=4000
